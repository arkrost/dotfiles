[user]
	name = Arkady Rost
	email = arkrost@gmail.com
[core]
	autocrlf = input
	safecrlf = true
	editor = vim
[alias]
	co = checkout
	ci = commit
	st = status -uno
	br = branch
	type = cat-file -t
	dump = cat-file -p
	lg = log --graph --color --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	unstage = rm --cached
[color]
	ui = true
[man]
	viewer = man
[stash]
	showPatch = true
