
function prompt_local_precmd {
  # Get Git repository information.
  if (( $+functions[git-info] )); then
    git-info
  fi
}

function prompt_local_setup {
  setopt LOCAL_OPTIONS
  unsetopt XTRACE KSH_ARRAYS
  prompt_opts=(cr percent subst)

  # Load required functions.
  autoload -Uz add-zsh-hook

  # Add hook to set up prompt parameters before each command.
  add-zsh-hook precmd prompt_local_precmd

  _prompt_local_colors=(
    "%F{magenta}"
    "%F{yellow}"
    "%F{cyan}"
    "%F{red}"
    "%F{green}"
  )

  # Set git-info parameters.
  zstyle ':prezto:module:git:info' verbose 'yes'
  zstyle ':prezto:module:git:info:branch' format "${_prompt_local_colors[1]}%b%f"
  zstyle ':prezto:module:git:info:added' format "${_prompt_local_colors[5]}●%f"
  zstyle ':prezto:module:git:info:deleted' format "${_prompt_local_colors[2]}●%f"
  zstyle ':prezto:module:git:info:modified' format "${_prompt_local_colors[4]}●%f"
  zstyle ':prezto:module:git:info:untracked' format "${_prompt_local_colors[3]}●%f"
  zstyle ':prezto:module:git:info:keys' format 'prompt' '(%b%d%a%m%u)'
  
  # Define prompts.
  PROMPT="${_prompt_local_colors[3]}%n%f at ${_prompt_local_colors[2]}%m%f ${_prompt_local_colors[5]}%~%f "'${git_info:+${(e)git_info[prompt]}}'"$ "
}

prompt_local_setup "$@"
