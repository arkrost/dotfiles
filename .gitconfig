[user]
	name = Arkady Rost
	email = arkrost@gmail.com
[core]
	autocrlf = input
	safecrlf = true
	editor = vim
[push]
	default = simple
[alias]
    co = checkout
    ci = commit
    st = status
    br = branch
    type = cat-file -t
    dump = cat-file -p
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	unstage = reset HEAD
[color]
	ui = true
[man]
	viewer = man
[diff]
[merge]
	tool = vimdiff
[mergetool]
	keepBackup = false
[diff]
	tool = vimdiff
[difftool]
	prompt = false
